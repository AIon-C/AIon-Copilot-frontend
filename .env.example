# .env.local


NEXT_PUBLIC_API_URL=

# disabled next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# Copilot API mode (client-side, controls mock/stub/real behaviour)
NEXT_PUBLIC_COPILOT_API_MODE=real
# Client-side request timeout for the local proxy (milliseconds, not sensitive)
NEXT_PUBLIC_COPILOT_API_TIMEOUT_MS=15000

# Copilot API (server-side only — never exposed to the browser)
# For localhost frontend + deployed ai-agent API, set your deployed endpoint.
COPILOT_API_BASE_URL=https://your-ai-agent.example.com
# Optional fallback token used only when request Authorization is not present.
COPILOT_API_TOKEN=your-service-jwt-token
