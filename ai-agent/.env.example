# サーバー
PORT=3001

# データベース (Mastra Memory 用)
DATABASE_URL=postgres://user:pass@host:5432/chatapp?sslmode=disable

# Redis (Go が書き込んだコンテキストキャッシュの読取)
REDIS_URL=redis://localhost:6379

# 認証 (Go Backend と同じ秘密鍵)
JWT_SECRET=same-as-go-backend

# Go Backend (コンテキスト取得のフォールバック)
GO_BACKEND_URL=http://localhost:8080

# Gemini API (ローカル開発)
GOOGLE_GENERATIVE_AI_API_KEY=your-api-key

# Vertex AI (本番 – Workload Identity で自動認証、キー不要)
# GCP_PROJECT_ID=your-project
# GCP_LOCATION=asia-northeast1
